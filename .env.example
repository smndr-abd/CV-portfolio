# ─────────────────────────────────────────────────
# Copy this file to .env.local (local dev) and add
# these as Environment Variables in Vercel dashboard
# ─────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin panel password (you'll type this to log into /admin)
ADMIN_PASSWORD=your-strong-admin-password

# Gmail credentials for email notifications
# Use an App Password, NOT your real Gmail password
# Get from: Google Account → Security → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send contact form notifications (defaults to GMAIL_USER if not set)
NOTIFY_EMAIL=your@gmail.com

# Frontend URL (for CORS) — your Vercel deployment URL
FRONTEND_URL=https://your-portfolio.vercel.app
